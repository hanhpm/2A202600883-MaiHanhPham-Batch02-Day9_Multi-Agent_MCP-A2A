# Preferred: official OpenAI API
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini

# Optional fallback: OpenRouter-compatible API
# OPENROUTER_API_KEY=your_key_here
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

REGISTRY_URL=http://localhost:10000

# Latency demo: 1 skips the Customer ReAct LLM and delegates directly to Law Agent.
# Set to 0 to compare against the original Customer ReAct behavior.
CUSTOMER_FAST_DELEGATE=1

# Optional: live trace endpoint used by start_all.ps1 + UI
TRACE_EVENT_URL=http://localhost:8000/api/trace
